{
  "name": "heat-maps-front",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "set-env": "node -r dotenv/config -e \"const f=require('fs'),p=process.env;if(!p.API_URL||!p.ENCRYPTION_KEY){console.error('ERROR: faltan API_URL o ENCRYPTION_KEY en .env');process.exit(1);}f.writeFileSync('src/app/core/config.ts','export const apiUrl='+JSON.stringify(p.API_URL+'/api')+';\\nexport const encryptionKey='+JSON.stringify(p.ENCRYPTION_KEY)+';\\n');console.log('config.ts generado desde .env');\"",
    "prestart": "npm run set-env",
    "prebuild": "npm run set-env",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "dotenv": "^16.5.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
